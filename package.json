{
  "name": "vite-plugin-lucide-sprite",
  "version": "2.0.0-beta.1",
  "description": "Vite plugin that generates one SVG sprite from Lucide, Simple Icons, and local SVG symbol sets",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vite-plugin-lucide-sprite": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./codemod": {
      "types": "./dist/codemod.d.ts",
      "import": "./dist/codemod.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "vite",
    "vite-plugin",
    "svelte",
    "lucide",
    "simple-icons",
    "svg-sprite",
    "icons"
  ],
  "author": "mustafa0x",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mustafa0x/vite-plugin-lucide-sprite.git"
  },
  "bugs": {
    "url": "https://github.com/mustafa0x/vite-plugin-lucide-sprite/issues"
  },
  "homepage": "https://github.com/mustafa0x/vite-plugin-lucide-sprite#readme",
  "peerDependencies": {
    "lucide-static": ">=0.400.0",
    "simple-icons": ">=10.0.0",
    "svelte": ">=5",
    "vite": ">=5"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "svelte": "^5.55.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "peerDependenciesMeta": {
    "lucide-static": {
      "optional": true
    },
    "simple-icons": {
      "optional": true
    }
  }
}
